# Database Configuration
# SQLAlchemy with MySQL or SQLite
DATABASE_TYPE=sqlite

# Environment Configuration
# Controls logging levels for MySQL operations
# Options: development (DEBUG level logging) or production (INFO level logging)
ENVIRONMENT=development

# SQLAlchemy Database URL
# For SQLite (local development):
DATABASE_URL=sqlite:///./recipe_saver.db

# For MySQL (local):
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/recipe_saver

# For MySQL (AWS RDS):
# DATABASE_URL=mysql+pymysql://admin:your_password@your-rds-endpoint.region.rds.amazonaws.com:3306/recipe_saver

# For MySQL (Google Cloud SQL):
# DATABASE_URL=mysql+pymysql://root:your_password@your-cloud-sql-ip:3306/recipe_saver

# MySQL Connection Parameters (alternative to DATABASE_URL)
# If DATABASE_URL is not set, these will be used to build the connection string
# MYSQL_USER=root
# MYSQL_PASSWORD=password
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DATABASE=recipe_saver

# Application Settings
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24
UPLOAD_DIR=uploads
